{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Flask (Debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "app.main:app",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--no-debugger",
        "--no-reload",
        "--port", "8000"
      ],
      "jinja": true,
      "python": "${workspaceFolder}/.venv/bin/python"
    }
  ]
}
